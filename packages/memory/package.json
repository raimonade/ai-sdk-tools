{
  "name": "@raimonade/ai-sdk-tools-memory",
  "version": "2.1.5",
  "description": "Persistent memory system for AI agents",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./*": {
      "types": "./dist/providers/*.d.ts",
      "import": "./dist/providers/*.js",
      "require": "./dist/providers/*.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "@upstash/redis": "^1.34.3",
    "ai": "^6.0.3",
    "drizzle-orm": "^0.36.0",
    "kysely": "^0.28.3",
    "ioredis": "^5.0.0",
    "redis": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "@upstash/redis": {
      "optional": true
    },
    "ai": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    },
    "kysely": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "redis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@upstash/redis": "^1.35.8",
    "drizzle-orm": "^0.45.1",
    "kysely": "^0.28.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "@raimonade/ai-sdk-tools-debug": "workspace:*"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
