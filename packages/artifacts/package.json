{
  "name": "@raimonade/ai-sdk-tools-artifacts",
  "private": false,
  "version": "2.2.0",
  "description": "Advanced streaming interfaces for AI applications",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs",
      "require": "./dist/client.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "bun run build",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "ai",
    "artifacts",
    "streaming",
    "react",
    "ai-sdk",
    "typescript"
  ],
  "author": "Pontus Abrahamsson",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/raimonade/ai-sdk-tools.git"
  },
  "bugs": {
    "url": "https://github.com/raimonade/ai-sdk-tools/issues"
  },
  "homepage": "https://github.com/raimonade/ai-sdk-tools#readme",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "dependencies": {
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@ai-sdk/react": "^3.0.3",
    "@types/react": "^19.2.7",
    "typescript": "^5.9.3",
    "tsup": "^8.5.1",
    "@raimonade/ai-sdk-tools-store": "workspace:*"
  },
  "peerDependencies": {
    "ai": "^6.0.3",
    "react": "^18.0.0 || ^19.0.0"
  }
}
